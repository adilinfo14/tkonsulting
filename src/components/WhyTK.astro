---
const differentiators = [
  {
    num: '01',
    title: 'Interlocuteur unique',
    desc:  'Un seul point de contact, du diagnostic à la livraison. Pas de sous-traitance opaque, pas de turn-over d\'équipe.',
  },
  {
    num: '02',
    title: 'Approche sur mesure',
    desc:  'Chaque mission est conçue pour vous, pas adaptée d\'un modèle générique. Votre contexte est unique, notre réponse l\'est aussi.',
  },
  {
    num: '03',
    title: 'Expertise terrain',
    desc:  'Nous avons piloté des projets complexes dans des environnements contraints. Nous connaissons les obstacles avant qu\'ils ne se présentent.',
  },
  {
    num: '04',
    title: 'Engagement de moyens',
    desc:  'Nous mobilisons toute notre expertise sur chaque mission. La qualité de l\'accompagnement prime sur toute promesse de résultat.',
  },
  {
    num: '05',
    title: 'Communication directe',
    desc:  'Reporting régulier, transparence totale sur l\'avancement et les risques. Vous ne découvrez jamais les mauvaises nouvelles trop tard.',
  },
  {
    num: '06',
    title: 'Réseau d\'experts',
    desc:  'Au-delà de nos compétences, vous accédez à un écosystème de partenaires spécialisés : technique, juridique, financier, digital.',
  },
];

const stats = [
  { val: '3+',  label: 'Années d\'activité' },
  { val: '1',   label: 'Interlocuteur dédié' },
  { val: '24h', label: 'Délai de réponse' },
  { val: '0',   label: 'Frais cachés' },
];
---
<section id="pourquoi" class="relative py-28 md:py-36 overflow-hidden">
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-tk-gold/20 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-12">

    <!-- En-tête éditorial : titre massif + texte en regard -->
    <div class="reveal mb-20">
      <p class="text-xs tracking-[0.3em] uppercase text-tk-gold mb-8">Notre différence</p>
      <div class="grid lg:grid-cols-[3fr_2fr] gap-12 lg:items-end">
        <h2 class="font-serif font-light text-5xl md:text-7xl lg:text-[5.5rem] text-white leading-[1.0] tracking-tight">
          Pourquoi<br/>
          <span class="text-gold-grad font-semibold italic">TKonsulting</span>
        </h2>
        <p class="text-tk-muted text-base md:text-lg leading-relaxed max-w-sm lg:pb-2">
          Dans un marché saturé de consultants, nous faisons le pari de la proximité, de la transparence et de l'engagement réel.
        </p>
      </div>
    </div>

    <!-- Bande de chiffres sans fond — lignes uniquement -->
    <div class="reveal mb-24 border-t border-b border-tk-gold/15 py-10" style="transition-delay: 100ms;">
      <div class="flex flex-wrap md:flex-nowrap items-center">
        {stats.map((s, i) => (
          <div class={[
            'flex-1 min-w-[50%] md:min-w-0 py-4 md:py-0 text-center',
            i > 0 ? 'border-l border-tk-gold/15 md:border-l md:border-tk-gold/15' : '',
          ].join(' ')} style={`padding-left: ${i > 0 ? '2rem' : '0'}; padding-right: 2rem;`}>
            <p class="font-serif text-5xl md:text-6xl lg:text-7xl font-bold text-gold-grad leading-none mb-2">{s.val}</p>
            <p class="text-xs tracking-[0.15em] uppercase text-tk-muted">{s.label}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Liste numérotée éditoriale — zéro carte, lignes de séparation -->
    <div class="grid md:grid-cols-2 reveal" style="transition-delay: 200ms;">
      {differentiators.map((d, i) => (
        <div class={[
          'flex gap-5 py-8',
          'border-t border-tk-gold/10',
          i % 2 === 0 ? 'md:pr-16' : 'md:pl-16 md:border-l md:border-tk-gold/10',
        ].join(' ')}>
          <!-- Numéro typographique en watermark -->
          <span
            class="font-serif text-5xl font-bold leading-none shrink-0 select-none mt-0.5"
            style="color: rgba(201,168,76,0.13);"
          >{d.num}</span>
          <div>
            <h3 class="text-xs tracking-[0.2em] uppercase text-tk-gold mb-2">{d.title}</h3>
            <p class="text-sm text-tk-muted leading-relaxed">{d.desc}</p>
          </div>
        </div>
      ))}
    </div>

  </div>

  <div class="absolute bottom-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-tk-gold/20 to-transparent"></div>
</section>
