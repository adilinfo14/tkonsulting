---
const differentiators = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
    </svg>`,
    title: 'Interlocuteur unique',
    desc:  'Un seul point de contact, du diagnostic à la livraison. Pas de sous-traitance opaque, pas de turn-over d\'équipe.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
    </svg>`,
    title: 'Approche sur mesure',
    desc:  'Chaque mission est conçue pour vous, pas adaptée d\'un modèle générique. Votre contexte est unique, notre réponse l\'est aussi.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
    </svg>`,
    title: 'Expertise terrain',
    desc:  'Nous avons piloté des projets complexes dans des environnements contraints. Nous connaissons les obstacles avant qu\'ils ne se présentent.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/>
    </svg>`,
    title: 'Engagement de moyens',
    desc:  'Nous mobilisons toute notre expertise et notre rigueur sur chaque mission. Notre engagement porte sur la qualité de l\'accompagnement, pas sur des promesses de résultats.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/>
    </svg>`,
    title: 'Communication directe',
    desc:  'Reporting régulier, transparence totale sur l\'avancement, les risques et les décisions. Vous ne découvrez jamais les mauvaises nouvelles trop tard.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/>
    </svg>`,
    title: 'Réseau d\'experts',
    desc:  'Au-delà de nos compétences, vous accédez à un écosystème de partenaires spécialisés : technique, juridique, financier, digital.',
  },
];
---
<section id="pourquoi" class="relative py-28 md:py-36">
  <!-- Border top -->
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-tk-gold/20 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-12">

    <!-- Header -->
    <div class="grid lg:grid-cols-2 gap-16 items-center mb-20">
      <div class="reveal">
        <p class="text-xs tracking-[0.3em] uppercase text-tk-gold mb-4">Notre différence</p>
        <h2 class="font-serif font-light text-4xl md:text-5xl text-white mb-6 leading-tight">
          Pourquoi choisir<br/>
          <span class="text-gold-grad font-semibold">TKonsulting ?</span>
        </h2>
        <p class="text-tk-muted text-lg leading-relaxed">
          Dans un marché saturé de consultants, nous faisons le pari de la proximité, de la transparence et de l'engagement réel sur vos résultats.
        </p>
      </div>

      <!-- Stats column -->
      <div class="grid grid-cols-2 gap-6 reveal" style="transition-delay: 150ms;">
        {[
          { val: '100%', label: 'Engagement de moyens' },
          { val: '1',    label: 'Interlocuteur dédié' },
          { val: '24h',  label: 'Délai de réponse garanti' },
          { val: '0',    label: 'Frais cachés' },
        ].map(s => (
          <div class="card-glass p-6 text-center">
            <p class="font-serif text-3xl font-bold text-gold-grad mb-1">{s.val}</p>
            <p class="text-xs text-tk-muted tracking-wide">{s.label}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Grid of differentiators -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {differentiators.map((d, i) => (
        <div
          class="reveal flex gap-5 p-6 card-glass"
          style={`transition-delay: ${i * 80}ms;`}
        >
          <div
            class="shrink-0 w-12 h-12 rounded-lg flex items-center justify-center"
            style="background: rgba(201,168,76,0.08); border: 1px solid rgba(201,168,76,0.15);"
          >
            <span class="text-tk-gold" set:html={d.icon} />
          </div>
          <div>
            <h3 class="font-semibold text-white text-lg mb-1">{d.title}</h3>
            <p class="text-base text-tk-muted leading-relaxed">{d.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Border bottom -->
  <div class="absolute bottom-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-tk-gold/20 to-transparent"></div>
</section>
