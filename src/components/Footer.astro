---
const year = new Date().getFullYear();
const links = [
  { href: '/#services', label: 'Services' },
  { href: '/#methode',  label: 'Méthode' },
  { href: '/#pourquoi', label: 'Pourquoi nous' },
  { href: '/contact',   label: 'Contact' },
];
---
<footer class="relative border-t border-tk-border">
  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-16">
    <div class="grid md:grid-cols-3 gap-12 mb-12">

      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="inline-block mb-4">
          <span class="font-serif text-2xl">
            <span class="text-gold-grad font-bold">TK</span><span class="text-white font-light tracking-widest text-lg">ONSULTING</span>
          </span>
        </a>
        <p class="text-tk-muted text-sm leading-relaxed mb-4 max-w-xs">
          Cabinet de conseil en stratégie, pilotage de projets et transformation digitale.
        </p>
        <div class="flex items-center gap-2 text-xs tracking-widest uppercase text-tk-gold/70">
          <span>Stratégie</span>
          <span class="text-tk-border">•</span>
          <span>Projets</span>
          <span class="text-tk-border">•</span>
          <span>Image de marque</span>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <p class="text-xs tracking-[0.2em] uppercase text-tk-gold mb-6">Navigation</p>
        <ul class="space-y-3">
          {links.map(l => (
            <li>
              <a href={l.href} class="text-sm text-tk-muted hover:text-tk-gold-light transition-colors">
                {l.label}
              </a>
            </li>
          ))}
          <li class="pt-2 border-t border-tk-border mt-2">
            <a
              href="https://lesensia.com"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-tk-muted hover:text-tk-gold-light transition-colors flex items-center gap-2"
            >
              lesensia.com
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-tk-gold/50">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
              </svg>
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="text-xs tracking-[0.2em] uppercase text-tk-gold mb-6">Contact</p>
        <ul class="space-y-4">
          <li>
            <a
              href="mailto:tkonsulting79@gmail.com"
              class="flex items-center gap-3 text-sm text-tk-muted hover:text-tk-gold-light transition-colors group"
            >
              <svg class="text-tk-gold shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
              </svg>
              tkonsulting79@gmail.com
            </a>
          </li>
          <li>
            <a
              href="https://www.linkedin.com/company/tkonsulting"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 text-sm text-tk-muted hover:text-tk-gold-light transition-colors"
            >
              <svg class="text-tk-gold shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
              </svg>
              LinkedIn
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-tk-border pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-tk-muted">
        &copy; {year} TKonsulting. Tous droits réservés.
      </p>
      <div class="flex items-center gap-6">
        <a href="/mentions-legales" class="text-xs text-tk-muted hover:text-tk-gold transition-colors">Mentions légales</a>
        <a href="/politique-confidentialite" class="text-xs text-tk-muted hover:text-tk-gold transition-colors">Confidentialité</a>
      </div>
    </div>
  </div>
</footer>
