---
const pilliers = [
  {
    label: 'Conseil',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/>
    </svg>`,
  },
  {
    label: 'Transformation',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"/>
    </svg>`,
  },
  {
    label: 'Automatisation',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z"/>
    </svg>`,
  },
];
---
<section
  id="hero"
  class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden"
  style="background: radial-gradient(ellipse 80% 60% at 50% 40%, #1a1508 0%, #110e06 30%, #0A0A0A 70%);"
>
  <!-- Particle trail (comet, top-right comme sur le logo) -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <span class="particle" style="width:11px;height:11px;top:20%;left:61%;--dur:5.2s;--del:0s;"></span>
    <span class="particle" style="width:8px; height:8px; top:17%;left:65%;--dur:4.8s;--del:0.5s;"></span>
    <span class="particle" style="width:6px; height:6px; top:14%;left:69%;--dur:6s;  --del:1s;"></span>
    <span class="particle" style="width:4px; height:4px; top:11%;left:72%;--dur:5.5s;--del:1.4s;"></span>
    <span class="particle" style="width:3px; height:3px; top:8%; left:75%;--dur:4.5s;--del:1.9s;"></span>
    <span class="particle" style="width:2px; height:2px; top:6%; left:78%;--dur:5s;  --del:2.3s; opacity:0.4;"></span>
    <!-- Ambient -->
    <span class="particle" style="width:3px;height:3px;top:78%;left:12%;--dur:7s;--del:0.5s;opacity:0.2;"></span>
    <span class="particle" style="width:2px;height:2px;top:35%;left:18%;--dur:8s;--del:1s; opacity:0.15;"></span>
    <span class="particle" style="width:3px;height:3px;top:62%;left:84%;--dur:6s;--del:2s; opacity:0.18;"></span>
  </div>

  <!-- Vignette overlay -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
    style="background: radial-gradient(ellipse 70% 60% at 50% 38%, transparent 40%, rgba(0,0,0,0.55) 100%);">
  </div>

  <!-- Gold ambient glow under logo -->
  <div class="absolute pointer-events-none" aria-hidden="true"
    style="top:18%;left:50%;transform:translateX(-50%);width:320px;height:320px;
           background:radial-gradient(circle, rgba(201,168,76,0.08) 0%, transparent 65%);
           border-radius:50%;">
  </div>

  <!-- Diag gold line -->
  <div class="absolute pointer-events-none" aria-hidden="true"
    style="top:50%;left:54%;width:350px;height:1px;
           background:linear-gradient(90deg,transparent,rgba(201,168,76,0.1),transparent);
           transform:rotate(-35deg);">
  </div>

  <!-- ── Content card ── -->
  <div class="relative w-full max-w-4xl mx-auto px-6 text-center pt-28 pb-24">

    <!-- Logo image -->
    <div class="flex justify-center mb-3">
      <img
        src="/logo-tk.png"
        alt="TKonsulting"
        class="h-44 md:h-52 w-auto"
        style="mix-blend-mode: screen; filter: drop-shadow(0 0 40px rgba(201,168,76,0.5));"
        onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
      />
      <!-- Fallback SVG fidèle à la carte logo -->
      <div style="display:none;" class="flex flex-col items-center gap-0">
        <div
          class="w-44 h-44 rounded-full flex items-center justify-center"
          style="border: 1.5px solid #C9A84C; background: radial-gradient(circle, rgba(201,168,76,0.07) 0%, transparent 70%);"
        >
          <span class="font-serif text-7xl font-bold text-gold-grad leading-none">TK</span>
        </div>
      </div>
    </div>

    <!-- Diamond separator -->
    <div class="flex items-center justify-center gap-4 mb-2">
      <div class="h-px w-20 bg-gradient-to-r from-transparent to-tk-gold opacity-40"></div>
      <svg width="7" height="7" viewBox="0 0 8 8" fill="#C9A84C" opacity="0.7"><path d="M4 0L8 4L4 8L0 4Z"/></svg>
      <div class="h-px w-20 bg-gradient-to-l from-transparent to-tk-gold opacity-40"></div>
    </div>

    <!-- Tagline row -->
    <p class="text-xs md:text-sm tracking-[0.28em] uppercase mb-7" style="color:rgba(201,168,76,0.7);">
      Stratégie &nbsp;·&nbsp; Projets &nbsp;·&nbsp; Image de Marque
    </p>

    <!-- H1 -->
    <h1 class="font-serif font-light text-5xl md:text-6xl lg:text-7xl leading-[1.08] mb-5 text-white">
      Pilotez vos projets.<br/>
      <span class="text-gold-grad font-semibold italic">Transformez</span> vos idées.<br/>
      Automatisez votre succès.
    </h1>

    <!-- Subtitle — engagement de moyens -->
    <p class="max-w-2xl mx-auto text-lg md:text-xl text-tk-muted leading-relaxed mb-10">
      Cabinet de conseil en stratégie, pilotage de projets et transformation digitale.
      Un interlocuteur dédié, une expertise mobilisée à 100&nbsp;% pour votre projet.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-14">
      <a href="mailto:tkonsulting79@gmail.com?subject=Prise%20de%20contact%20TKonsulting" class="btn-gold">
        Prendre contact
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
      <a href="#services" class="btn-outline">
        Nos services
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
      </a>
    </div>

    <!-- ── 3 pilliers (comme sur la carte logo) ── -->
    <div class="flex items-start justify-center gap-6 md:gap-12">
      {pilliers.map((p, i) => (
        <>
          <div class="flex flex-col items-center gap-3">
            <div
              class="w-16 h-16 md:w-20 md:h-20 rounded-full flex items-center justify-center"
              style="border: 1px solid rgba(201,168,76,0.35); background: rgba(201,168,76,0.06);"
            >
              <span class="text-tk-gold" set:html={p.icon} />
            </div>
            <p class="text-xs tracking-[0.22em] uppercase" style="color:rgba(201,168,76,0.75);">{p.label}</p>
          </div>
          {i < 2 && (
            <div class="self-center w-px h-10 mt-1" style="background: rgba(201,168,76,0.2);"></div>
          )}
        </>
      ))}
    </div>
  </div>

  <!-- Scroll indicator -->
  <a href="#services"
     class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-tk-muted hover:text-tk-gold transition-colors"
     aria-label="Défiler">
    <span class="text-xs tracking-[0.2em] uppercase">Découvrir</span>
    <span class="w-px h-8 bg-gradient-to-b from-tk-gold to-transparent animate-pulse"></span>
  </a>
</section>

<style>
  .particle {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(circle, #E2C97A 0%, #C9A84C 55%, transparent 100%);
    animation: pfloat var(--dur) ease-in-out infinite var(--del);
    opacity: 0.75;
  }
  @keyframes pfloat {
    0%,100% { transform: translateY(0)    scale(1);    opacity: 0.65; }
    50%      { transform: translateY(-20px) scale(1.18); opacity: 1; }
  }
</style>
