---
const steps = [
  {
    num:   '01',
    title: 'Diagnostic',
    desc:  'Nous analysons en profondeur votre contexte, vos enjeux et vos objectifs stratégiques. Aucune hypothèse par défaut — tout part de votre réalité terrain.',
    icon:  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
    </svg>`,
  },
  {
    num:   '02',
    title: 'Stratégie',
    desc:  'Nous co-construisons un plan d\'action sur mesure, priorisé et chiffré. Chaque décision est argumentée, chaque risque est adressé.',
    icon:  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z"/>
    </svg>`,
  },
  {
    num:   '03',
    title: 'Pilotage',
    desc:  'Nous exécutons avec rigueur et agilité. Vous disposez d\'un interlocuteur unique, d\'un reporting transparent et d\'une capacité d\'adaptation en temps réel.',
    icon:  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
    </svg>`,
  },
  {
    num:   '04',
    title: 'Résultats',
    desc:  'Nous mesurons l\'impact réel de chaque initiative et ajustons pour maximiser la valeur délivrée. Votre succès est notre seul indicateur de performance.',
    icon:  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 002.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 012.916.52 6.003 6.003 0 01-5.395 4.972m0 0a6.726 6.726 0 01-2.749 1.35m0 0a6.772 6.772 0 01-3.044 0"/>
    </svg>`,
  },
];
---
<section id="methode" class="section-light relative py-28 md:py-36 overflow-hidden">

  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-tk-gold/25 to-transparent"></div>
  <div class="absolute bottom-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-tk-gold/25 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-12">

    <!-- Header -->
    <div class="text-center mb-20 reveal">
      <p class="text-xs tracking-[0.3em] uppercase text-tk-gold mb-4">Notre approche</p>
      <h2 class="font-serif font-light text-4xl md:text-5xl text-stone-900 mb-6">
        Une méthode <span class="text-gold-grad font-semibold">en 4 étapes</span>
      </h2>
      <p class="max-w-xl mx-auto text-stone-500 text-lg leading-relaxed">
        Rigoureuse et adaptable, notre démarche transforme chaque engagement en valeur mesurable.
      </p>
    </div>

    <!-- Steps -->
    <div class="relative">
      <!-- Connector line (desktop only) -->
      <div
        class="hidden lg:block absolute top-10 left-[calc(12.5%+32px)] right-[calc(12.5%+32px)] h-px"
        style="background: linear-gradient(90deg, transparent, rgba(201,168,76,0.35) 20%, rgba(201,168,76,0.35) 80%, transparent);"
      ></div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-6">
        {steps.map((step, i) => (
          <div class="reveal relative flex flex-col items-center text-center" style={`transition-delay: ${i * 100}ms;`}>

            <!-- Number circle -->
            <div class="relative z-10 mb-6">
              <div
                class="w-20 h-20 rounded-full flex items-center justify-center"
                style="background: linear-gradient(135deg, rgba(201,168,76,0.18), rgba(201,168,76,0.06)); border: 1px solid rgba(201,168,76,0.35);"
              >
                <span class="font-serif text-2xl font-bold text-gold-grad">{step.num}</span>
              </div>
              <!-- Icon overlay — fond ivoire pour correspondre à la section -->
              <div
                class="absolute -bottom-1 -right-1 w-8 h-8 rounded-full flex items-center justify-center"
                style="background: #F7F3EC; border: 1px solid rgba(201,168,76,0.4);"
              >
                <span class="text-tk-gold" set:html={step.icon} style="transform: scale(0.65);" />
              </div>
            </div>

            <h3 class="font-serif text-2xl font-semibold text-stone-900 mb-3">{step.title}</h3>
            <p class="text-stone-500 text-base leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

</section>
