---
---
<section class="relative py-28 md:py-36 overflow-hidden">
  <!-- Gold background glow -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(201,168,76,0.07) 0%, transparent 70%);"
  ></div>

  <!-- Subtle corner lines -->
  <div class="absolute top-0 left-0 w-32 h-32 border-l border-t border-tk-gold/10 pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 w-32 h-32 border-r border-b border-tk-gold/10 pointer-events-none"></div>

  <div class="relative max-w-4xl mx-auto px-6 text-center reveal">
    <p class="text-xs tracking-[0.3em] uppercase text-tk-gold mb-6">Passez à l'action</p>

    <h2 class="font-serif font-light text-4xl md:text-6xl text-white mb-6 leading-tight">
      Prêt à transformer<br/>
      <span class="text-gold-grad font-semibold">votre ambition en résultats ?</span>
    </h2>

    <p class="text-tk-muted text-lg leading-relaxed mb-12 max-w-2xl mx-auto">
      Un premier échange de 30 minutes, sans engagement. Nous écoutons, nous analysons, nous vous proposons une approche adaptée à votre situation.
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
      <a href="/contact" class="btn-gold text-sm">
        Demander un premier échange
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
        </svg>
      </a>
      <a href="mailto:tkonsulting79@gmail.com" class="btn-outline text-sm">
        Email direct
      </a>
    </div>

    <!-- Trust signals -->
    <div class="flex items-center justify-center gap-8 flex-wrap">
      {[
        'Réponse sous 24h',
        'Premier échange gratuit',
        'Sans engagement',
      ].map(t => (
        <div class="flex items-center gap-2 text-sm text-tk-muted">
          <svg class="text-tk-gold" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
          </svg>
          {t}
        </div>
      ))}
    </div>
  </div>
</section>
